---
import BlogInfo from '@components/astro/BlogInfo.astro';
import Page from '@components/astro/Page.astro';

import { getCollection } from 'astro:content';
import { slide } from 'astro:transitions';

/* get all posts, to list them in the archive page */
const posts = await getCollection('posts').then((posts) =>
  posts
    .sort((a, b) => b.data.createdDate.getTime() - a.data.createdDate.getTime())
    .slice(0, 10),
);
---

<Page title="廢話集散空間" description="什麼都可能寫，喜歡也好，不喜歡也好。">
  <div class="flex flex-col text-neutral-800">
    <BlogInfo />

    <ul
      class="list-disc px-4"
      transition:animate={slide({
        duration: 150,
      })}
    >
      {
        posts.map((post) => (
          <li class="ml-5 px-1 pt-3">
            <a class="flex flex-col gap-1" href={`/posts/${post.slug}`}>
              <span class="font-bold">{post.data.title}</span>

              <div class="flex flex-row place-items-center gap-2">
                <span>
                  {post.data.tags.map((tag) => (
                    <span class="rounded-md border-2 border-neutral-300 px-1 text-sm font-medium text-neutral-400">
                      #{tag}
                    </span>
                  ))}
                </span>

                <span class="text-sm font-medium text-neutral-400">
                  {post.data.createdDate.toLocaleDateString()}
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Page>
