---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

import WebMention from '@components/WebMention.astro';
import Page from '@components/Page.astro';

import { blogConfig } from '@config/blog';
import { mkArticleStructuredData } from '@models/StructuredData';

import { mkLocaleDateString } from '@utils/date';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts');

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await post.render();
---

<Page
  title={post.data.title}
  description={post.data.description || post.data.title}
  structuredData={mkArticleStructuredData(blogConfig)(post)}
>
  <div class="h-entry px-4" transition:animate={blogConfig.transition}>
    <div class="mb-3 border-b-2 border-neutral-400 pb-2 pt-4">
      <h1 class="p-name text-2xl font-bold text-neutral-800">
        {post.data.title}
      </h1>

      <!-- hidden self-link -->
      <a
        hidden
        class="u-url"
        href=`https://blog.rileycki.com/posts/${post.slug}`></a>

      <div class="my-1 flex flex-row gap-1">
        {
          post.data.tags.map((tag) => (
            <div class="rounded-md border-2 border-neutral-300 px-1 text-sm font-medium text-neutral-400">
              #{tag}
            </div>
          ))
        }
      </div>

      <div class="h-card my-1 text-sm font-medium text-neutral-400">
        作者：<a
          href="https://blog.rileycki.com"
          class="p-author p-name u-url underline">Riley Chang</a
        >
      </div>

      <div class="text-sm font-medium text-neutral-400">
        發佈日期：<time
          class="dt-published"
          datetime={post.data.createdDate.toISOString()}
          >{mkLocaleDateString(blogConfig)(post.data.createdDate)}</time
        >
      </div>
    </div>

    <article class="prose prose-neutral overflow-y-scroll px-1">
      <Content />
    </article>

    <div class="mb-6 mt-6 border-t-2 border-dashed border-neutral-400 pt-5">
      <WebMention url={`https://blog.rileycki.com/posts/${post.slug}/`} />
    </div>
  </div>
</Page>
