---
import { getCollection } from 'astro:content';
import { slide } from 'astro:transitions';

import BlogInfo from '@components/astro/BlogInfo.astro';
import Page from '@components/astro/Page.astro';

/* take first 10 posts, ordered by created date, to generate index */
const posts = await getCollection('posts').then((posts) =>
  posts
    .sort((a, b) => b.data.createdDate.getTime() - a.data.createdDate.getTime())
    .slice(0, 10),
);
---

<Page title="廢話集散空間" description="什麼都可能寫，喜歡也好，不喜歡也好。">
  <div class="flex flex-col">
    <BlogInfo />

    <ul
      class="px-4"
      transition:animate={slide({
        duration: 150,
      })}
    >
      {
        posts.map((post) => (
          <li class="border-b-2 border-dashed border-neutral-400 px-1 py-3">
            <a href={`/posts/${post.slug}`}>
              <article>
                <h2 class="text-lg font-bold">{post.data.title}</h2>

                <p class="mb-1">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-md border-2 border-neutral-300 px-1 text-xs font-medium text-neutral-400">
                      #{tag}
                    </span>
                  ))}
                </p>

                <p class="mb-1 text-xs text-neutral-400">
                  {post.data.createdDate.toLocaleDateString()}
                </p>

                {post.data.cover ? (
                  <img class="my-2" src={post.data.cover} />
                ) : null}

                <p class="text-sm text-neutral-800">{post.data.description}</p>
              </article>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="p-3 text-center text-sm font-medium italic text-neutral-600">
      ~主頁僅顯示最近十則~
    </p>
  </div>
</Page>
