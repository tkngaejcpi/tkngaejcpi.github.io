---
import ArticleList from "@components/ArticleList.astro";
import Navigation from "@components/Navigation.astro";
import Page from "@components/Page.astro";

import { firstN, mkArticleQueryByTag } from "@models/ArticleQuery";
import { pipe } from "@utils/pipe";

const showingTags = ["Example"];
---

<Page title="Riley's Blog" description="Riley's Blog">
	<div class="flex flex-col">
		<Navigation />

		<div class="flex flex-col gap-2">
			{
				showingTags.map((tag) => (
					<div class="p-2">
						<h2 class="font-bold">{tag}</h2>
						<ArticleList
							articleQuery={pipe(
								mkArticleQueryByTag(tag),
								firstN(5),
							)}
						/>
					</div>
				))
			}
		</div>
	</div>
</Page>
