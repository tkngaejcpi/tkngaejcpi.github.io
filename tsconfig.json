{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": "src/",
    "paths": {
      "@components/*": ["components/*"],
      "@config/*": ["config/*"],
      "@models/*": ["models/*"],
      "@utils/*": ["utils/*"]
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  }
}
